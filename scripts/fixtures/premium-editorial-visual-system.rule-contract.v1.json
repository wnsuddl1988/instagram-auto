      { "id": "same_camera_distance_repeat_limit", "rule": "동일 cameraDistance 연속 반복 제한 — close-up이 연속 2 scene 초과 금지.", "appliesTo": "cameraDistance" },
      { "id": "same_object_family_repeat_limit", "rule": "동일 objectFamily 연속 2 scene 초과 사용 금지.", "appliesTo": "objectFamily" },
      { "id": "smartphone_centered_repeat_limit", "rule": "smartphone-centered scene은 전체 6 scene 중 최대 2개.", "appliesTo": "objectFamily" },
      { "id": "wood_table_notebook_coffee_hand_combo_limit", "rule": "wood table + notebook + coffee + hand 조합 반복 금지 — 이 조합으로 수렴하면 실패.", "appliesTo": "composition" },
      { "id": "fullscreen_data_card_ban", "rule": "전체 화면 data-card 반복/지배 금지.", "appliesTo": "graphicLayer" },
      { "id": "hand_table_smartphone_convergence_ban", "rule": "6장면 모두 손/테이블/스마트폰 구도로 수렴 금지.", "appliesTo": "composition" },
      { "id": "scene_category_must_differ", "rule": "scene별 visualCategory가 충분히 구분되어야 한다 — 인접 scene의 category 중복 최소화.", "appliesTo": "visualCategory" },
      { "id": "previous_history_as_compiler_input", "rule": "이전 scene 사용 이력(공간/구도/object family/category)을 prompt compiler 입력(previousSceneVisualHistory)으로 사용한다.", "appliesTo": "promptCompilerInput" }
